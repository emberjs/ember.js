    "rollup": "^4.57.1",
    "router_js": "workspace:*",
    "rsvp": "^4.8.5",
    "terser": "^5.42.0",
    "testem": "^3.20.1",
    "testem-failure-only-reporter": "^1.0.0",
    "tracerbench": "^8.0.1",
